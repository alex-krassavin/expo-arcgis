---
import Search from 'virtual:starlight/components/Search';
import config from 'virtual:starlight/user-config';

const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const path = Astro.url.pathname;
const inApi = path.includes('/api');
const inGuides = !inApi && (path.includes('/guides') || path.includes('/samples'));
---

<div class="ea-header">
  <a href={`${base}/`} class="ea-logo">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <circle cx="12" cy="12" r="9.2" stroke="#0E9C8E" stroke-width="1.3"></circle>
      <path d="M12 2.8v18.4M2.8 12h18.4" stroke="#0E9C8E" stroke-width="1" opacity=".5"></path>
      <circle cx="12" cy="12" r="2.3" fill="#0E9C8E"></circle>
    </svg>
    <span>expo-arcgis</span>
  </a>

  <div class="ea-actions">
    {shouldRenderSearch && <div class="ea-search not-content"><Search /></div>}
    <a href={`${base}/guides/getting-started/`} class:list={['ea-tab', { 'ea-tab--active': inGuides }]}>Guides</a>
    <a href={`${base}/api/`} class:list={['ea-tab', { 'ea-tab--active': inApi }]}>API</a>
    <a
      href="https://github.com/alex-krassavin/expo-arcgis"
      class="ea-gh"
      aria-label="View expo-arcgis on GitHub"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"
        ><path
          d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38v-1.33c-2.23.48-2.7-1.07-2.7-1.07-.36-.93-.89-1.18-.89-1.18-.73-.5.05-.49.05-.49.8.06 1.23.83 1.23.83.71 1.23 1.87.87 2.33.66.07-.52.28-.87.5-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.83-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 014 0c1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.52.56.83 1.28.83 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.2c0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"
        ></path></svg
      >
    </a>
  </div>
</div>
