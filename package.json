{
  "name": "expo-arcgis",
  "version": "0.1.3",
  "description": "ArcGIS Maps SDK for React Native — native Android (Kotlin) & iOS (Swift) map rendering as an Expo module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "files": [
    "build",
    "src",
    "android/src",
    "android/build.gradle",
    "ios/*.swift",
    "ios/*.podspec",
    "expo-module.config.json",
    "app.plugin.js",
    "plugin/build"
  ],
  "scripts": {
    "build": "node internal/module_scripts/build.js",
    "build:plugin": "node internal/module_scripts/build.js plugin",
    "clean": "node internal/module_scripts/clean.js",
    "lint": "eslint src/",
    "test": "node internal/module_scripts/test.js",
    "check:package": "publint && attw --pack --profile esm-only --ignore-rules unexpected-module-syntax",
    "prepare": "node internal/module_scripts/prepare.js",
    "open:ios": "node internal/module_scripts/open-ios.js",
    "open:android": "node internal/module_scripts/open-android.js"
  },
  "keywords": [
    "react-native",
    "expo",
    "arcgis",
    "esri",
    "maps",
    "mapview",
    "ExpoArcgis"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alex-krassavin/expo-arcgis.git"
  },
  "bugs": {
    "url": "https://github.com/alex-krassavin/expo-arcgis/issues"
  },
  "author": "krassavin <walonade@icloud.com>",
  "license": "MIT",
  "homepage": "https://alex-krassavin.github.io/expo-arcgis",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@babel/core": "^7.26.0",
    "@types/jest": "^29.2.1",
    "@types/react": "~19.1.1",
    "babel-preset-expo": "~55.0.8",
    "eslint": "~9.39.4",
    "eslint-config-universe": "^15.0.3",
    "expo": "^56.0.7",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.9",
    "prettier": "^3.0.0",
    "publint": "^0.3.21",
    "react-native": "0.82.1",
    "typescript": "^5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "roots": [
      "<rootDir>/src"
    ]
  },
  "peerDependencies": {
    "expo": ">=54.0.0",
    "react": ">=18.2.0",
    "react-native": ">=0.74.0"
  }
}
